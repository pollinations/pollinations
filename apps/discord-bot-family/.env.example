# Pollinations API
TEXT_POLLINATIONS_TOKEN=your_pollinations_api_key

# Bot tokens (named by model: BOT_TOKEN_<MODEL_UPPER>, dashes become underscores)
# e.g. model "gemini-search" -> BOT_TOKEN_GEMINI_SEARCH
BOT_TOKEN_KIMI=your_discord_bot_token
BOT_TOKEN_GEMINI_SEARCH=your_discord_bot_token
BOT_TOKEN_PERPLEXITY_FAST=your_discord_bot_token
BOT_TOKEN_DEEPSEEK=your_discord_bot_token
BOT_TOKEN_MINIMAX=your_discord_bot_token
BOT_TOKEN_GEMINI_HYBRID=your_discord_bot_token
