# Copy to .env (gitignored) and fill in real values. Never commit this file
# with real secrets — .env is already excluded via ../.gitignore.

# sk_ token used by monitor.mjs to probe community models through gen.pollinations.ai.
ENTER_API_TOKEN=sk_xxx

# Prod Tinybird read token, for model_health / recent_server_errors pipes.
#   sops -d enter.pollinations.ai/secrets/prod.vars.json | jq -r '.TINYBIRD_READ_TOKEN'
TINYBIRD_READ_TOKEN=p.eyJ...

# 1 (default) = Claude Code logs what it would deactivate but never calls the
# D1 update. Only set to 0 after a soak period of reviewing dry-run output
# confirms good judgment.
MONITOR_DRY_RUN=1

# Required only when MONITOR_DRY_RUN=0. In dry-run, loop.sh unsets this before
# invoking Claude Code so the agent cannot accidentally write to D1.
# CLOUDFLARE_API_TOKEN=xxx

# Claude Code's own auth — either an Anthropic API key, or leave unset if the
# box is configured to use `claude-code-router` pointed at gen.pollinations.ai
# (see .github/workflows/issue-polly-auto-fix.yml for that pattern).
# ANTHROPIC_API_KEY=sk-ant-xxx
