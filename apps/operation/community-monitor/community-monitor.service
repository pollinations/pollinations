[Unit]
Description=Community Model Monitor Loop
Wants=network-online.target
After=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/monitor
EnvironmentFile=/home/ubuntu/monitor/.env
ExecStartPre=-/home/ubuntu/monitor/update-from-repo.sh
ExecStart=/home/ubuntu/monitor/loop.sh
Restart=always
RestartSec=900
RuntimeMaxSec=2700
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
