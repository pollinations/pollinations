{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pollinations.ai/schemas/economics/ingest-entry.v1.json",
  "title": "IngestEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "entry_id",
    "source_file",
    "provider",
    "invoice_id",
    "issued_at",
    "period_start",
    "period_end",
    "amount",
    "currency",
    "cost_category",
    "model",
    "op_cloud_type",
    "op_transaction_category",
    "should_match_op_transaction",
    "should_match_op_cloud",
    "usage_summary",
    "cost_details",
    "reconciliation_notes"
  ],
  "properties": {
    "schema_version": { "const": "ingest_entry.v1" },
    "entry_id": { "type": "string" },
    "source_file": { "type": "string" },
    "provider": { "type": ["string", "null"] },
    "invoice_id": { "type": ["string", "null"] },
    "issued_at": { "type": ["string", "null"] },
    "period_start": { "type": ["string", "null"] },
    "period_end": { "type": ["string", "null"] },
    "amount": { "type": ["number", "null"] },
    "currency": { "type": ["string", "null"] },
    "cost_category": {
      "type": "string",
      "enum": [
        "admin",
        "credit",
        "gpu",
        "inference_serverless",
        "infrastructure",
        "model",
        "network",
        "office",
        "payroll",
        "revenue",
        "support",
        "storage",
        "tax",
        "unknown"
      ]
    },
    "model": { "type": ["string", "null"] },
    "op_cloud_type": {
      "type": ["string", "null"],
      "enum": ["infra", "gpu", "inference", null]
    },
    "op_transaction_category": {
      "type": ["string", "null"],
      "enum": ["cloud", "saas", "payroll", "admin", "office", "revenue", null]
    },
    "should_match_op_transaction": { "type": "boolean" },
    "should_match_op_cloud": { "type": "boolean" },
    "usage_summary": { "type": "string" },
    "cost_details": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "amount", "currency"],
        "properties": {
          "label": { "type": "string" },
          "amount": { "type": ["number", "null"] },
          "currency": { "type": ["string", "null"] }
        }
      }
    },
    "reconciliation_notes": { "type": "string" }
  }
}
