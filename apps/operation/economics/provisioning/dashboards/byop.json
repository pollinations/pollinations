          "rawSql": "WITH pk_owners AS (\n  SELECT name AS app_name, user_id\n  FROM d1_apikey\n  WHERE JSONExtractString(metadata, 'keyType') = 'publishable'\n)\nSELECT\n  toStartOfInterval(start_time, INTERVAL 1 DAY) as time,\n  uniq(user_github_id) as byop_users,\n  uniq(if(api_key_created_for_app != 'undefined', api_key_created_for_app, api_key_name)) as byop_apps,\n  uniq(pk.user_id) as byop_devs\nFROM generation_event\nLEFT JOIN pk_owners AS pk ON if(api_key_created_for_app != 'undefined', api_key_created_for_app, api_key_name) = pk.app_name\nWHERE $__timeFilter(start_time)\n  AND environment = 'production'\n  AND response_status >= 200 AND response_status < 300\n  AND total_price > 0\n  AND user_github_id != '' AND user_github_id != 'undefined'\n  AND (api_key_created_via = 'redirect-auth' OR (api_key_type = 'secret' AND api_key_name LIKE '%.%'))\n  AND (start_time < toDateTime('2025-12-30 16:59:45') OR start_time > toDateTime('2026-01-08 18:19:58'))\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
