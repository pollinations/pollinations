      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 1,
          "rawSql": "WITH banned_users AS (\n  SELECT github_username\n  FROM d1_user\n  WHERE banned = 1\n  GROUP BY github_username\n),\nowner_clean AS (\n  SELECT\n    id AS user_id,\n    github_username\n  FROM d1_user\n  WHERE github_username != '' AND github_username != 'undefined'\n),\nowner_fallback AS (\n  SELECT\n    name AS app_name,\n    user_id\n  FROM d1_apikey\n  WHERE JSONExtractString(metadata, 'keyType') = 'publishable'\n)\nSELECT\n  app,\n  owner,\n  signal,\n  users,\n  requests,\n  pack_pollen,\n  tier_pollen,\n  total_pollen,\n  avg_per_user,\n  if(pack_pollen + tier_pollen > 0, (pack_pollen - tier_pollen) / (pack_pollen + tier_pollen), 0) as profitability\nFROM (\n  SELECT\n    app,\n    any(resolved_owner) as owner,\n    any(resolved_signal) as signal,\n    count() as users,\n    sum(user_total) / count() as avg_per_user,\n    sum(tier_pollen) as tier_pollen,\n    sum(pack_pollen) as pack_pollen,\n    sum(user_total) as total_pollen,\n    sum(requests) as requests\n  FROM (\n    SELECT\n      if(api_key_created_for_app != 'undefined', api_key_created_for_app, api_key_name) as app,\n      if(user_github_username != '' AND user_github_username != 'undefined', user_github_username, user_github_id) as user,\n      sumIf(total_price, selected_meter_slug IN ('v1:meter:tier', 'local:tier')) as tier_pollen,\n      sumIf(total_price, selected_meter_slug IN ('v1:meter:pack', 'local:pack')) as pack_pollen,\n      sum(total_price) as user_total,\n      count() as requests,\n      any(api_key_created_for_user_id) as owner_user_id,\n      if(countIf(api_key_created_via = 'redirect-auth') > 0, 'clean', 'heuristic') as app_signal\n    FROM generation_event\n    WHERE $__timeFilter(start_time)\n      AND environment = 'production'\n      AND response_status >= 200 AND response_status < 300\n      AND user_github_username NOT IN (SELECT github_username FROM banned_users)\n      AND total_price > 0\n      AND (api_key_created_via = 'redirect-auth' OR (api_key_type = 'secret' AND api_key_name LIKE '%.%'))\n      AND user_github_id != ''\n      AND (start_time < toDateTime('2025-12-30 16:59:45') OR start_time > toDateTime('2026-01-08 18:19:58'))\n    GROUP BY app, user\n  ) AS per_user\n  LEFT JOIN (\n    SELECT\n      app,\n      multiIf(\n        clean.github_username != '' AND clean.github_username IS NOT NULL, clean.github_username,\n        fallback_user.github_username != '' AND fallback_user.github_username IS NOT NULL, fallback_user.github_username,\n        ''\n      ) as resolved_owner,\n      if(clean.github_username != '' AND clean.github_username IS NOT NULL, 'clean', 'heuristic') as resolved_signal\n    FROM (\n      SELECT DISTINCT\n        if(api_key_created_for_app != 'undefined', api_key_created_for_app, api_key_name) as app,\n        any(api_key_created_for_user_id) as owner_user_id\n      FROM generation_event\n      WHERE $__timeFilter(start_time)\n        AND environment = 'production'\n        AND (api_key_created_via = 'redirect-auth' OR (api_key_type = 'secret' AND api_key_name LIKE '%.%'))\n      GROUP BY app\n    ) AS apps\n    LEFT JOIN owner_clean AS clean ON apps.owner_user_id = clean.user_id\n    LEFT JOIN owner_fallback AS fb ON apps.app = fb.app_name\n    LEFT JOIN owner_clean AS fallback_user ON fb.user_id = fallback_user.user_id\n  ) AS owners ON per_user.app = owners.app\n  GROUP BY app\n  ORDER BY total_pollen DESC\n)",
          "refId": "A"
        }
      ],
      "title": "BYOP App Ranking",
      "type": "table"
    }
