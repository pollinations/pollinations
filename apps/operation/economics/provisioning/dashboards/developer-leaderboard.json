                    "format": 0,
                    "range": true,
                    "rawSql": "WITH banned_users AS (SELECT github_username FROM d1_user WHERE banned = 1 GROUP BY github_username)\nSELECT\n  toStartOfInterval(start_time, INTERVAL ${bucket}) AS time,\n  uniqIf(if(user_github_username != '' AND user_github_username != 'undefined', user_github_username, user_github_id), user_github_id != '') AS active_devs,\n  uniqIf(api_key_name, length(api_key_name) > 0 AND api_key_name != 'undefined') AS apps\nFROM generation_event\nWHERE $__timeFilter(start_time)\n  AND environment = 'production'\n  AND response_status >= 200 AND response_status < 300\n  AND total_price > 0\n  AND user_github_username NOT IN (SELECT github_username FROM banned_users)\n  AND (start_time < toDateTime('2025-12-30 16:59:45') OR start_time > toDateTime('2026-01-08 18:19:58'))\nGROUP BY time ORDER BY time",
