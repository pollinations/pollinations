            },
            "pluginVersion": "12.4.0",
            "targets": [
                {
                    "datasource": {
                        "type": "grafana-clickhouse-datasource",
                        "uid": "PAD1A0A25CD30D456"
                    },
                    "format": 1,
                    "rawSql": "WITH banned_users AS (SELECT github_username FROM d1_user WHERE banned = 1 GROUP BY github_username),\nkey_owners AS (\n  SELECT\n    du.github_username AS github_username,\n    toUInt32(countIf(JSONExtractString(ak.metadata, 'keyType') = 'secret' OR JSONExtractString(ak.metadata, 'keyType') = '')) AS sk_keys,\n    toUInt32(countIf(JSONExtractString(ak.metadata, 'keyType') = 'publishable')) AS pk_keys\n  FROM d1_apikey ak\n  LEFT JOIN d1_user du ON ak.user_id = du.id\n  WHERE du.github_username != '' AND du.github_username != 'undefined'\n  GROUP BY du.github_username\n)\nSELECT\n  developer,\n  apps,\n  total_pollen,\n  pack_pollen,\n  tier_pollen,\n  requests,\n  if(byop_events > 0, '\u2713', '') AS byop,\n  ifNull(ko.sk_keys, 0) AS sk,\n  ifNull(ko.pk_keys, 0) AS pk\nFROM (\n  SELECT\n    if(user_github_username != '' AND user_github_username != 'undefined', user_github_username, user_github_id) AS developer,\n    uniqIf(api_key_name, length(api_key_name) > 0 AND api_key_name != 'undefined') AS apps,\n    sum(total_price) AS total_pollen,\n    sumIf(total_price, selected_meter_slug IN ('v1:meter:pack', 'local:pack')) AS pack_pollen,\n    sumIf(total_price, selected_meter_slug IN ('v1:meter:tier', 'local:tier')) AS tier_pollen,\n    count() AS requests,\n    countIf(\n      (api_key_client_id != '' AND api_key_client_id != 'undefined')\n      OR (api_key_type = 'secret' AND api_key_name LIKE '%.%')\n    ) AS byop_events\n  FROM generation_event\n  WHERE $__timeFilter(start_time)\n    AND environment = 'production'\n    AND response_status >= 200 AND response_status < 300\n    AND total_price > 0\n    AND user_github_username NOT IN (SELECT github_username FROM banned_users)\n    AND user_github_id != ''\n    AND (start_time < toDateTime('2025-12-30 16:59:45') OR start_time > toDateTime('2026-01-08 18:19:58'))\n  GROUP BY developer\n) dev\nLEFT JOIN key_owners ko ON dev.developer = ko.github_username\nORDER BY total_pollen DESC\nLIMIT 500",
                    "refId": "A"
                }
            ],
            "title": "All Developers \u2014 ranked by Pollen",
            "type": "table"
        },
