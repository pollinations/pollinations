          "rawSql": "WITH top_countries AS (\n  SELECT JSONExtractString(payload, 'data', 'object', 'customer_details', 'address', 'country') AS c\n  FROM stripe_event\n  WHERE timestamp >= $__fromTime AND timestamp < $__toTime\n    AND event_type = 'checkout.session.completed'\n    AND payment_status = 'paid'\n    AND livemode = 1\n  GROUP BY c\n  HAVING c != ''\n  ORDER BY SUM(amount_cents) DESC\n  LIMIT 5\n)\nSELECT\n  toStartOfInterval(timestamp, INTERVAL 1 $granularity) AS time,\n  if(country IN (SELECT c FROM top_countries), country, 'Other') AS country,\n  round(SUM(amount_cents) / 100.0, 2) AS revenue\nFROM (\n  SELECT\n    timestamp,\n    amount_cents,\n    JSONExtractString(payload, 'data', 'object', 'customer_details', 'address', 'country') AS country\n  FROM stripe_event\n  WHERE timestamp >= $__fromTime AND timestamp < $__toTime\n    AND event_type = 'checkout.session.completed'\n    AND payment_status = 'paid'\n    AND livemode = 1\n)\nGROUP BY time, country\nORDER BY time",
