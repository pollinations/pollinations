          "format": 1,
          "rawSql": "SELECT\n  JSONExtractString(payload, 'data', 'object', 'customer_details', 'address', 'country') AS country,\n  round(SUM(amount_cents) / 100.0, 2) AS revenue\nFROM stripe_event\nWHERE timestamp >= $__fromTime AND timestamp < $__toTime\n  AND event_type = 'checkout.session.completed'\n  AND payment_status = 'paid'\n  AND livemode = 1\nGROUP BY country\nHAVING country != ''\nORDER BY revenue DESC\nLIMIT 15",
