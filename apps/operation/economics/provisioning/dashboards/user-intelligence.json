      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  ts,\n  if(prev > 0, round((registrations - prev) / prev * 100, 1), null) AS growth_pct\nFROM (\n  SELECT\n    ts,\n    registrations,\n    lagInFrame(registrations) OVER (ORDER BY ts ASC) AS prev\n  FROM (\n    SELECT\n      date_trunc('$granularity', fromUnixTimestamp(assumeNotNull(created_at))) AS ts,\n      count() AS registrations\n    FROM d1_user\n    WHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n      AND created_at IS NOT NULL\n      AND $__timeFilter(fromUnixTimestamp(created_at))\n    GROUP BY ts\n    ORDER BY ts ASC\n  )\n)\nWHERE prev IS NOT NULL",
          "refId": "A"
        }
      ],
      "title": "Registration Growth Rate",
      "type": "timeseries"
    },
