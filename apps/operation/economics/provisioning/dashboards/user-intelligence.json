      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  ts,\n  sum(user_tier) OVER (ORDER BY ts ASC) AS user_tier,\n  sum(dev_tier) OVER (ORDER BY ts ASC) AS dev_tier,\n  sum(abuser_tier) OVER (ORDER BY ts ASC) AS abuser_tier,\n  sum(dead_tier) OVER (ORDER BY ts ASC) AS dead_tier\nFROM (\n  SELECT\n    date_trunc('$granularity', fromUnixTimestamp(assumeNotNull(created_at))) AS ts,\n    countIf(tier = 'spore' AND banned = 0) AS user_tier,\n    countIf(tier IN ('seed', 'flower', 'nectar') AND banned = 0) AS dev_tier,\n    countIf(tier = 'microbe' AND banned = 0) AS abuser_tier,\n    countIf(banned = 1) AS dead_tier\n  FROM d1_user\n  WHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n    AND created_at IS NOT NULL\n    AND $__timeFilter(fromUnixTimestamp(created_at))\n  GROUP BY ts\n  ORDER BY ts ASC\n)",
          "refId": "A"
        }
      ],
      "title": "Cumulative Registrations (User vs Dev)",
      "type": "timeseries"
    },
