          "format": 1,
          "rawSql": "SELECT\n  multiIf(\n    amount_cents = 200, '$2',\n    amount_cents = 500, '$5',\n    amount_cents = 1000, '$10',\n    amount_cents = 2000, '$20',\n    amount_cents = 5000, '$50',\n    amount_cents = 10000, '$100',\n    'Other'\n  ) AS pack,\n  count() AS purchases\nFROM stripe_event\nWHERE timestamp >= $__fromTime AND timestamp < $__toTime\n  AND event_type = 'checkout.session.completed'\n  AND payment_status = 'paid'\n  AND livemode = 1\nGROUP BY pack\nORDER BY purchases DESC",
