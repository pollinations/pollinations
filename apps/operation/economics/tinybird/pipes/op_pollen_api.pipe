TOKEN "treasury_web" READ

NODE endpoint
SQL >
    SELECT
        source,
        month,
        vendor,
        model,
        currency,
        cost_paid,
        cost_quests,
        price_paid,
        price_quests,
        byop_paid,
        byop_quests,
        model_paid,
        model_quests,
        requests_paid,
        requests_quests,
        requests_paid + requests_quests AS requests
    FROM op_pollen
    ORDER BY month, vendor, model

TYPE ENDPOINT
