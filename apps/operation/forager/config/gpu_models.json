{
  "runpod": [
    {"match": "zimage", "model": "zimage", "kind": "gpu"},
    {"match": "klein", "model": "klein", "kind": "gpu"},
    {"match": "_storage", "model": "zimage", "kind": "gpu", "exact": true}
  ],
  "lambda": [
    {"match": ["gh200", "sana", "ltx", "ace"], "model": "ltx-2,acestep,sana", "kind": "gpu"},
    {"match": "", "model": "", "kind": "gpu"}
  ],
  "vast.ai": [
    {"match": "", "model": "flux", "kind": "gpu"}
  ],
  "modal": [
    {"match": "", "model": "flux-klein,klein,klein-large", "kind": "serverless"}
  ],
  "io.net": [
    {"match": "", "model": "flux,zimage", "kind": "gpu"}
  ]
}
