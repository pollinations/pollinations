TOKEN "treasury_ingest" APPEND
TOKEN "treasury_ingest" READ

SCHEMA >
    `month` String `json:$.month`,
    `provider` String `json:$.provider`,
    `currency` String `json:$.currency`,
    `credit_amount` Float64 `json:$.credit_amount`,
    `cash_amount` Float64 `json:$.cash_amount`,
    `source` String `json:$.source`

ENGINE "MergeTree"
ENGINE_SORTING_KEY "provider, month"

FORWARD_QUERY >
    SELECT month, provider, currency, credit_amount, cash_amount, source
