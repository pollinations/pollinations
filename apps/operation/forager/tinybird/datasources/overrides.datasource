TOKEN "treasury_ingest" APPEND
TOKEN "treasury_ingest" READ

SCHEMA >
    `entered_at` DateTime `json:$.entered_at`,
    `scope` String `json:$.scope`,
    `key` String `json:$.key`,
    `field` String `json:$.field`,
    `value_num` Nullable(Float64) `json:$.value_num`,
    `value_str` String `json:$.value_str`,
    `note` String `json:$.note`

ENGINE "MergeTree"
ENGINE_SORTING_KEY "scope, key, field, entered_at"
