TOKEN "treasury_ingest" APPEND
TOKEN "treasury_ingest" READ

SCHEMA >
    `date` Date `json:$.date`,
    `vendor` String `json:$.vendor`,
    `category` String `json:$.category`,
    `charged_amount` Float64 `json:$.charged_amount`,
    `charged_currency` String `json:$.charged_currency`

ENGINE "MergeTree"
ENGINE_SORTING_KEY "date, vendor, category"

FORWARD_QUERY >
    SELECT
        date,
        vendor,
        category,
        charged_amount,
        charged_currency
