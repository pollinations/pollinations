TOKEN "treasury_web" READ

NODE gaps
SQL >
    SELECT month, provider, billing, status, invoice_usd, payment_usd,
           round(invoice_usd - payment_usd, 2) AS delta_usd,
           invoice_refs, payment_refs, note
    FROM reconciliation
    WHERE status IN ('missing_invoice', 'amount_mismatch', 'needs_review', 'needs_label')
    ORDER BY month DESC, provider

TYPE endpoint
