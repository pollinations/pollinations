TOKEN "treasury_web" READ

NODE endpoint
SQL >
    SELECT sha256, provider, category, period_month, amount, currency, credit_usd,
           invoice_number, issued_at, source, file_ref, ingested_at
    FROM (
        SELECT *, row_number() OVER (
           PARTITION BY sha256
           ORDER BY (source IN ('manual', 'label')) DESC,
                     ingested_at DESC
        ) AS rn
        FROM invoices
    )
    WHERE rn = 1
    ORDER BY provider, period_month

TYPE endpoint
