TOKEN "treasury_web" READ

NODE endpoint
SQL >
    SELECT sha256, provider, category, period_month, amount, currency, credit_usd,
           invoice_number, issued_at, file_ref
    FROM (
        SELECT *, row_number() OVER (
           PARTITION BY sha256
           ORDER BY (source = 'label') DESC,
                     ingested_at DESC
        ) AS rn
        FROM invoices
    )
    WHERE rn = 1 AND status = 'parsed'
    ORDER BY provider, period_month

TYPE endpoint
