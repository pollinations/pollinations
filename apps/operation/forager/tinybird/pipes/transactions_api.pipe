TOKEN "treasury_web" READ

NODE endpoint
SQL >
    SELECT
        formatDateTime(date, '%F') AS date,
        provider,
        category,
        bank_charged_amount,
        bank_charged_currency,
        cash_paid_amount,
        cash_paid_currency,
        credit_burned_amount,
        credit_burned_currency,
        invoice_ref,
        match_status
    FROM transactions
    ORDER BY date DESC, provider, category, match_status

TYPE endpoint
