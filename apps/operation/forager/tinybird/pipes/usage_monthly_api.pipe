TOKEN "treasury_web" READ

NODE usage
SQL >
    SELECT
        month,
        'tinybird' AS source,
        vendor,
        model,
        currency,
        cost_paid,
        cost_quests,
        price_paid,
        price_quests,
        byop_paid,
        byop_quests,
        model_paid,
        model_quests
    FROM usage_monthly
    ORDER BY month, vendor, model

TYPE endpoint
