      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 1,
          "range": true,
          "rawSql": "SELECT\n  uniqIf(model, model != 'unknown') AS active_models,\n  uniqMerge(users) AS community_users,\n  sumMerge(successful_calls) AS community_calls,\n  round(\n    100 * sumMergeIf(successful_calls, is_byop = 1)\n    / nullIf(sumMerge(successful_calls), 0),\n    1\n  ) AS byop_share_pct,\n  round(\n    sumMergeIf(gross_consumption, is_byop = 0 AND funding_source = 'paid'),\n    2\n  ) AS direct_paid_consumption,\n  round(sumMerge(community_reward), 2) AS owner_rewards\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\n  AND is_community = 1",
          "refId": "A"
        }
      ],
      "title": "Community overview",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PAD1A0A25CD30D456"
      },
      "description": "Daily successful community-model calls split into direct traffic and BYOP traffic. This source query also supplies the following five charts so the dashboard makes only three Tinybird requests per refresh.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
