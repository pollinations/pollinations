          "rawSql": "SELECT\n  model,\n  sumMerge(successful_calls) AS calls,\n  uniqMerge(users) AS users,\n  round(sumMergeIf(gross_consumption, funding_source = 'paid'), 2) AS paid_pollen,\n  round(sumMergeIf(gross_consumption, funding_source = 'quest'), 2) AS quest_pollen,\n  round(\n    100 * sumMergeIf(successful_calls, is_byop = 1)\n    / nullIf(sumMerge(successful_calls), 0),\n    1\n  ) AS byop_share_pct,\n  round(\n    sumMergeIf(gross_consumption, is_byop = 0 AND funding_source = 'paid'),\n    2\n  ) AS direct_paid_pollen,\n  round(sumMerge(community_reward), 2) AS owner_reward\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\n  AND is_community = 1\nGROUP BY model\nORDER BY calls DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Community model ranking",
