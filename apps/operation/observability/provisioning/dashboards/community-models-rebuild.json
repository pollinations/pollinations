                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "byop_calls"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Through BYOP"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  toStartOfDay(hour) AS time,\n  sumMergeIf(successful_calls, is_community = 1 AND is_byop = 0) AS direct_calls,\n  sumMergeIf(successful_calls, is_community = 1 AND is_byop = 1) AS byop_calls,\n  round(\n    100 * sumMergeIf(successful_calls, is_community = 1)\n    / nullIf(sumMerge(successful_calls), 0),\n    2\n  ) AS community_share_pct,\n  uniqIf(model, is_community = 1 AND model != 'unknown') AS active_models,\n  uniqMergeIf(users, is_community = 1) AS community_users,\n  sumMergeIf(gross_consumption, is_community = 1 AND funding_source = 'paid') AS paid_consumption,\n  sumMergeIf(gross_consumption, is_community = 1 AND funding_source = 'quest') AS quest_consumption,\n  sumMergeIf(\n    gross_consumption,\n    is_community = 1 AND is_byop = 0 AND funding_source = 'paid'\n  ) AS direct_paid_consumption,\n  sumMergeIf(\n    gross_consumption,\n    is_community = 1 AND is_byop = 0 AND funding_source = 'quest'\n  ) AS direct_quest_consumption,\n  sumMergeIf(community_reward, is_community = 1 AND funding_source = 'paid') AS paid_rewards,\n  sumMergeIf(community_reward, is_community = 1 AND funding_source = 'quest') AS quest_rewards\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Direct vs BYOP community traffic",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "time",
                "direct_calls",
                "byop_calls"
              ]
            }
          }
        }
      ],
      "type": "timeseries"
    },
