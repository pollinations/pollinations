      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "WITH (\n  SELECT topKWeighted(8)(model, model_calls)\n  FROM (\n    SELECT model, sumMerge(successful_calls) AS model_calls\n    FROM generation_usage_hourly\n    WHERE $__timeFilter(hour)\n      AND environment IN ('production', 'debug-prod-copy')\n      AND business_stream = 'core'\n    GROUP BY model\n  )\n) AS top_models\nSELECT\n  toStartOfDay(hour) AS time,\n  if(has(top_models, model), model, 'Other') AS metric,\n  sumMerge(successful_calls) AS value\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\n  AND business_stream = 'core'\nGROUP BY time, metric\nORDER BY time, metric",
          "refId": "A"
        }
      ],
      "title": "Core model mix",
      "type": "timeseries"
    },
