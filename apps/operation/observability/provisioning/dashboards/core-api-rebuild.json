          "rawSql": "SELECT\n  model,\n  sumMerge(successful_calls) AS calls,\n  uniqMerge(users) AS users,\n  round(sumMergeIf(gross_consumption, funding_source = 'paid'), 2) AS paid_pollen,\n  round(sumMergeIf(gross_consumption, funding_source = 'quest'), 2) AS quest_pollen,\n  sumMerge(prompt_text_tokens)\n    + sumMerge(prompt_cached_tokens)\n    + sumMerge(prompt_cache_write_tokens)\n    + sumMerge(completion_text_tokens)\n    + sumMerge(completion_reasoning_tokens) AS text_tokens,\n  sumMerge(prompt_image_tokens) + sumMerge(completion_image_tokens) AS image_tokens,\n  round(sumMerge(prompt_audio_seconds) + sumMerge(completion_audio_seconds), 2) AS audio_seconds,\n  round(sumMerge(completion_video_seconds), 2) AS video_seconds\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\n  AND business_stream = 'core'\nGROUP BY model\nORDER BY calls DESC\nLIMIT 50",
