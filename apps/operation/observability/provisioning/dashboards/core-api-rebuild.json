        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 1,
          "range": true,
          "rawSql": "SELECT\n  sumMerge(successful_calls) AS core_calls,\n  uniqMerge(users) AS core_users,\n  round(sumMergeIf(gross_consumption, funding_source = 'paid'), 2) AS paid_consumption,\n  round(sumMergeIf(gross_consumption, funding_source = 'quest'), 2) AS quest_consumption\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\n  AND business_stream = 'core'",
          "refId": "A"
        }
      ],
      "title": "Core API overview",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PAD1A0A25CD30D456"
      },
      "description": "Daily successful Core API calls split by generation_event_v2 workload. This wide query also supplies active users, Paid/Quest consumption, platform share and usage-unit panels, limiting this eight-panel dashboard to four Tinybird requests per refresh.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 85,
            "lineWidth": 0,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  toStartOfDay(hour) AS time,\n  sumMergeIf(successful_calls, business_stream = 'core' AND workload = 'generate.text') AS text,\n  sumMergeIf(successful_calls, business_stream = 'core' AND workload = 'generate.image') AS image,\n  sumMergeIf(successful_calls, business_stream = 'core' AND workload = 'generate.embedding') AS embedding,\n  sumMergeIf(successful_calls, business_stream = 'core' AND workload = 'generate.audio') AS audio,\n  sumMergeIf(successful_calls, business_stream = 'core' AND workload = 'generate.video') AS video,\n  sumMergeIf(\n    successful_calls,\n    business_stream = 'core'\n    AND workload NOT IN (\n      'generate.text',\n      'generate.image',\n      'generate.embedding',\n      'generate.audio',\n      'generate.video'\n    )\n  ) AS other,\n  uniqMergeIf(users, business_stream = 'core') AS core_users,\n  sumMergeIf(gross_consumption, business_stream = 'core' AND funding_source = 'paid') AS paid_consumption,\n  sumMergeIf(gross_consumption, business_stream = 'core' AND funding_source = 'quest') AS quest_consumption,\n  round(\n    100 * sumMergeIf(successful_calls, business_stream = 'core')\n    / nullIf(sumMerge(successful_calls), 0),\n    2\n  ) AS core_share_pct,\n  sumMergeIf(prompt_text_tokens, business_stream = 'core')\n    + sumMergeIf(prompt_cached_tokens, business_stream = 'core')\n    + sumMergeIf(prompt_cache_write_tokens, business_stream = 'core')\n    + sumMergeIf(completion_text_tokens, business_stream = 'core')\n    + sumMergeIf(completion_reasoning_tokens, business_stream = 'core') AS text_tokens,\n  sumMergeIf(prompt_image_tokens, business_stream = 'core')\n    + sumMergeIf(completion_image_tokens, business_stream = 'core') AS image_tokens,\n  sumMergeIf(completion_video_tokens, business_stream = 'core') AS video_tokens,\n  round(\n    sumMergeIf(prompt_audio_seconds, business_stream = 'core')\n    + sumMergeIf(completion_audio_seconds, business_stream = 'core'),\n    2\n  ) AS audio_seconds,\n  round(sumMergeIf(completion_video_seconds, business_stream = 'core'), 2) AS video_seconds\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Core request volume",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "time",
                "text",
                "image",
                "embedding",
                "audio",
                "video",
                "other"
              ]
            }
          }
        }
      ],
      "type": "timeseries"
    },
