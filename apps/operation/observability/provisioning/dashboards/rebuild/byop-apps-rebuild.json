      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 1,
          "range": true,
          "rawSql": "SELECT\n  uniqIfMerge(apps) AS active_apps,\n  uniqMerge(users) AS app_users,\n  sumMerge(successful_calls) AS byop_calls,\n  round(sumMergeIf(gross_consumption, funding_source = 'paid'), 2) AS paid_consumption,\n  round(sumMergeIf(gross_consumption, funding_source = 'quest'), 2) AS quest_consumption,\n  round(sumMerge(byop_reward), 2) AS developer_rewards\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\n  AND is_byop = 1",
          "refId": "A"
        }
      ],
      "title": "BYOP overview",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PAD1A0A25CD30D456"
      },
      "description": "Daily successful BYOP calls split by generation_event_v2 workload. BYOP means api_key_client_id is populated; community-model calls made through BYOP remain in this dashboard.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 85,
            "lineWidth": 0,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  toStartOfDay(hour) AS time,\n  sumMergeIf(successful_calls, is_byop = 1 AND workload = 'generate.text') AS text,\n  sumMergeIf(successful_calls, is_byop = 1 AND workload = 'generate.image') AS image,\n  sumMergeIf(successful_calls, is_byop = 1 AND workload = 'generate.embedding') AS embedding,\n  sumMergeIf(successful_calls, is_byop = 1 AND workload = 'generate.audio') AS audio,\n  sumMergeIf(successful_calls, is_byop = 1 AND workload = 'generate.video') AS video,\n  sumMergeIf(\n    successful_calls,\n    is_byop = 1\n    AND workload NOT IN (\n      'generate.text',\n      'generate.image',\n      'generate.embedding',\n      'generate.audio',\n      'generate.video'\n    )\n  ) AS other,\n  round(\n    100 * sumMergeIf(successful_calls, is_byop = 1)\n    / nullIf(sumMerge(successful_calls), 0),\n    2\n  ) AS byop_share_pct,\n  uniqIfMergeIf(apps, is_byop = 1) AS active_apps,\n  uniqMergeIf(users, is_byop = 1) AS app_users,\n  sumMergeIf(gross_consumption, is_byop = 1 AND funding_source = 'paid') AS paid_consumption,\n  sumMergeIf(gross_consumption, is_byop = 1 AND funding_source = 'quest') AS quest_consumption,\n  sumMergeIf(successful_calls, is_byop = 1 AND is_community = 0) AS standard_calls,\n  sumMergeIf(successful_calls, is_byop = 1 AND is_community = 1) AS community_calls,\n  sumMergeIf(byop_reward, is_byop = 1 AND funding_source = 'paid') AS paid_rewards,\n  sumMergeIf(byop_reward, is_byop = 1 AND funding_source = 'quest') AS quest_rewards\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "BYOP request volume",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "time",
                "text",
                "image",
                "embedding",
                "audio",
                "video",
                "other"
              ]
            }
          }
        }
      ],
      "type": "timeseries"
    },
