          "rawSql": "WITH\n  app_rollup AS (\n    SELECT\n      app_id,\n      app_name,\n      owner_user_id,\n      sum(model_calls) AS calls,\n      uniqMerge(user_state) AS users,\n      round(sum(paid_pollen), 2) AS paid_pollen,\n      round(sum(quest_pollen), 2) AS quest_pollen,\n      round(sum(developer_reward), 2) AS developer_reward,\n      round(\n        100 * sumIf(model_calls, is_community) / nullIf(sum(model_calls), 0),\n        1\n      ) AS community_share_pct,\n      arrayStringConcat(topKWeighted(3)(model, model_calls), ', ') AS top_models\n    FROM (\n      SELECT\n        app_id,\n        app_name,\n        owner_user_id,\n        model,\n        is_community,\n        sumMerge(successful_calls) AS model_calls,\n        uniqMergeState(users) AS user_state,\n        sumMergeIf(gross_consumption, funding_source = 'paid') AS paid_pollen,\n        sumMergeIf(gross_consumption, funding_source = 'quest') AS quest_pollen,\n        sumMerge(byop_reward) AS developer_reward\n      FROM byop_app_daily\n      WHERE $__timeFilter(day)\n        AND environment IN ('production', 'debug-prod-copy')\n      GROUP BY app_id, app_name, owner_user_id, model, is_community\n    )\n    GROUP BY app_id, app_name, owner_user_id\n  ),\n  latest_users AS (\n    SELECT id, github_username\n    FROM d1_user\n    WHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n  )\nSELECT\n  a.app_name AS app,\n  coalesce(nullIf(u.github_username, ''), a.owner_user_id) AS owner,\n  a.calls,\n  a.users,\n  a.paid_pollen,\n  a.quest_pollen,\n  a.developer_reward,\n  a.community_share_pct,\n  a.top_models\nFROM app_rollup a\nLEFT JOIN latest_users u ON a.owner_user_id = u.id\nORDER BY a.calls DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Top BYOP apps",
      "type": "table"
    }
