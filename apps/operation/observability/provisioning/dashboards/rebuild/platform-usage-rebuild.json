          },
          "format": 0,
          "range": true,
          "rawSql": "WITH top_models AS (\n  SELECT model\n  FROM generation_usage_hourly\n  WHERE $__timeFilter(hour)\n    AND environment IN ('production', 'debug-prod-copy')\n  GROUP BY model\n  ORDER BY sumMerge(successful_calls) DESC\n  LIMIT 8\n)\nSELECT\n  toStartOfDay(hour) AS time,\n  if(model IN (SELECT model FROM top_models), model, 'Other') AS metric,\n  sumMerge(successful_calls) AS value\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\nGROUP BY time, metric\nORDER BY time, metric",
          "refId": "A"
        }
      ],
