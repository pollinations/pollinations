          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 1,
          "range": true,
          "rawSql": "SELECT\n  model,\n  sumMerge(successful_calls) AS calls,\n  uniqMerge(users) AS users,\n  uniqIfMerge(apps) AS apps,\n  round(sumMergeIf(gross_consumption, funding_source = 'paid'), 2) AS paid_pollen,\n  round(sumMergeIf(gross_consumption, funding_source = 'quest'), 2) AS quest_pollen\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\nGROUP BY model\nORDER BY calls DESC\nLIMIT 50",
          "refId": "A"
        }
