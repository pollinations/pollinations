          "range": true,
          "rawSql": "SELECT\n  r.registration_day AS time,\n  count() AS registrations,\n  countIf(\n    a.first_activity_time IS NOT NULL\n    AND a.first_activity_time >= fromUnixTimestamp(r.created_at_ts)\n    AND a.first_activity_time <= fromUnixTimestamp(r.created_at_ts) + INTERVAL 7 DAY\n  ) AS d7_activated\nFROM (\n  SELECT\n    id AS user_id,\n    assumeNotNull(created_at) AS created_at_ts,\n    toStartOfDay(fromUnixTimestamp(assumeNotNull(created_at))) AS registration_day\n  FROM d1_user\n  WHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n    AND banned = 0\n    AND created_at IS NOT NULL\n    AND fromUnixTimestamp(assumeNotNull(created_at)) >= $__fromTime\n    AND fromUnixTimestamp(assumeNotNull(created_at)) < $__toTime - INTERVAL 7 DAY\n) r\nLEFT JOIN (\n  SELECT\n    user_id,\n    minMerge(first_activity_time) AS first_activity_time\n  FROM user_first_activity_mv\n  GROUP BY user_id\n) a ON r.user_id = a.user_id\nGROUP BY r.registration_day\nORDER BY r.registration_day",
