          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  toStartOfDay(fromUnixTimestamp(assumeNotNull(created_at))) AS time,\n  count() AS registrations\nFROM d1_user\nWHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n  AND banned = 0\n  AND created_at IS NOT NULL\n  AND $__timeFilter(fromUnixTimestamp(assumeNotNull(created_at)))\nGROUP BY time\nORDER BY time",
