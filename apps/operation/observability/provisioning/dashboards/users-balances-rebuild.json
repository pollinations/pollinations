      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  time,\n  sum(registrations) OVER (ORDER BY time) AS cumulative_registrations\nFROM (\n  SELECT\n    toStartOfDay(fromUnixTimestamp(assumeNotNull(created_at))) AS time,\n    count() AS registrations\n  FROM d1_user\n  WHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n    AND banned = 0\n    AND created_at IS NOT NULL\n    AND $__timeFilter(fromUnixTimestamp(assumeNotNull(created_at)))\n  GROUP BY time\n)\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Cumulative registrations in range",
      "type": "timeseries"
    },
    {
