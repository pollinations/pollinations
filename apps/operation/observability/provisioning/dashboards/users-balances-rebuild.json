      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  toStartOfDay(hour) AS time,\n  funding_source AS metric,\n  sumMerge(gross_consumption) AS value\nFROM generation_usage_hourly\nWHERE $__timeFilter(hour)\n  AND environment IN ('production', 'debug-prod-copy')\n  AND funding_source IN ('paid', 'quest')\nGROUP BY time, metric\nORDER BY time, metric",
          "refId": "A"
        }
      ],
      "title": "Quest vs Paid spending",
      "type": "timeseries"
