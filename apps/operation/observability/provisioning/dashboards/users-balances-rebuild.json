      },
      "description": "Running total of registrations inside the selected range from the latest d1_user snapshot. It is not the platform's all-time user count and excludes accounts deleted before the latest sync.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 85,
