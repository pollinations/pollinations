    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PAD1A0A25CD30D456"
      },
      "description": "Current non-banned accounts ranked by the largest absolute Quest or Paid balance in the latest d1_user snapshot. Negative extremes are intentionally included because they can expose billing errors or abuse.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/.*_balance|magnitude/"
            },
            "properties": [
              {
                "id": "unit",
                "value": "suffix: Pollen"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "magnitude"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 1,
          "range": true,
          "rawSql": "SELECT\n  coalesce(nullIf(github_username, ''), nullIf(name, ''), id) AS user,\n  round(coalesce(tier_balance, 0), 2) AS quest_balance,\n  round(coalesce(pack_balance, 0), 2) AS paid_balance,\n  round(coalesce(tier_balance, 0) + coalesce(pack_balance, 0), 2) AS total_balance,\n  round(greatest(abs(coalesce(tier_balance, 0)), abs(coalesce(pack_balance, 0))), 2) AS magnitude\nFROM d1_user\nWHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n  AND banned = 0\nORDER BY magnitude DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Current balance extremes",
      "type": "table"
    },
