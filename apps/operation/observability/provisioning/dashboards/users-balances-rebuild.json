      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 1,
          "range": true,
          "rawSql": "SELECT\n  count() AS total_users,\n  countIf(\n    created_at IS NOT NULL\n    AND fromUnixTimestamp(assumeNotNull(created_at)) >= $__fromTime\n    AND fromUnixTimestamp(assumeNotNull(created_at)) < $__toTime\n  ) AS registrations,\n  round(sum(coalesce(tier_balance, 0)), 2) AS current_quest_balance,\n  round(sum(coalesce(pack_balance, 0)), 2) AS current_paid_balance,\n  countIf(coalesce(tier_balance, 0) < 0) AS negative_quest_accounts,\n  countIf(coalesce(pack_balance, 0) < 0) AS negative_paid_accounts\nFROM d1_user\nWHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n  AND banned = 0\nHAVING count() > 0",
          "refId": "A"
        }
      ],
      "title": "User and wallet overview",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PAD1A0A25CD30D456"
      },
      "description": "Daily sum of each active user's last observed Quest balance on a successful billed generation. This changes when the active population changes and is not the platform's complete historical wallet stock. One shared query also feeds the Paid and concentration panels.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 85,
            "lineWidth": 0,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "decimals": 2,
          "unit": "suffix: Pollen"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "observed_quest_balance"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Observed Quest balance"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PAD1A0A25CD30D456"
          },
          "format": 0,
          "range": true,
          "rawSql": "SELECT\n  day AS time,\n  round(sum(quest_balance), 2) AS observed_quest_balance,\n  round(sum(paid_balance), 2) AS observed_paid_balance,\n  round(quantile(0.95)(quest_balance), 2) AS quest_p95,\n  round(quantile(0.99)(quest_balance), 2) AS quest_p99,\n  round(max(quest_balance), 2) AS quest_max,\n  round(quantile(0.95)(paid_balance), 2) AS paid_p95,\n  round(quantile(0.99)(paid_balance), 2) AS paid_p99,\n  round(max(paid_balance), 2) AS paid_max,\n  count() AS active_users\nFROM (\n  SELECT\n    toStartOfDay(start_time) AS day,\n    user_id,\n    argMax(balances['v1:meter:tier'], start_time) AS quest_balance,\n    argMax(balances['v1:meter:pack'], start_time) AS paid_balance\n  FROM generation_event_v2\n  WHERE start_time >= greatest($__fromTime, toDateTime('2026-01-09 00:00:00'))\n    AND start_time < $__toTime\n    AND environment IN ('production', 'debug-prod-copy')\n    AND response_status >= 200\n    AND response_status < 300\n    AND is_billed_usage\n    AND user_id NOT IN ('', 'undefined')\n    AND user_id NOT IN (\n      SELECT id\n      FROM d1_user\n      WHERE synced_at = (SELECT max(synced_at) FROM d1_user)\n        AND banned = 1\n    )\n  GROUP BY day, user_id\n)\nGROUP BY day\nORDER BY day",
          "refId": "A"
        }
      ],
      "title": "Observed Quest balance — active users",
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "time",
                "observed_quest_balance"
              ]
            }
          }
        }
      ],
      "type": "timeseries"
    },
