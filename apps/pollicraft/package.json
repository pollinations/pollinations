{
	"name": "pollicraft",
	"private": true,
	"version": "0.0.1",
	"description": "An Infinite Craft-style browser game powered by Pollinations text and image generation.",
	"type": "module",
	"packageManager": "pnpm@10.10.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
