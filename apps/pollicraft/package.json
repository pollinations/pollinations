		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"pocketbase": "^0.26.8",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@lucide/svelte": "^1.3.0"
	}
