{
  "name": "minimal-cloudflare-agents-bee",
  "source": {
    "type": "git",
    "repository": "https://github.com/pollinations/pollinations.git",
    "ref": "main",
    "packagePath": "bees/minimal-cloudflare-agents"
  },
  "runtime": {
    "kind": "worker",
    "provider": "auto"
  },
  "surfaces": [
    "web",
    "a2a"
  ],
  "billing": {
    "mode": "user-pays",
    "clientId": "pk_replace_me",
    "dailyPollenLimit": 5
  },
  "state": {
    "backend": "sqlite",
    "retentionDays": 7
  }
}
