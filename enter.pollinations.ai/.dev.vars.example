# GitHub OAuth (for login)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Auth
BETTER_AUTH_SECRET=your_better_auth_secret_at_least_32_chars

# Polar (subscription/billing) - get from sandbox.polar.sh for dev
POLAR_ACCESS_TOKEN=your_polar_sandbox_access_token
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret

# Tinybird (analytics)
TINYBIRD_INGEST_TOKEN=your_tinybird_ingest_token
TINYBIRD_READ_TOKEN=your_tinybird_read_token
TINYBIRD_SYNC_TOKEN=your_tinybird_sync_token

# Testing
PLN_ENTER_TOKEN=optional_pln_enter_token

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# OVHcloud (Whisper speech-to-text, Qwen, Mistral)
OVHCLOUD_API_KEY=your_ovhcloud_api_key_here

# Alibaba DashScope (Qwen3-TTS)
DASHSCOPE_API_KEY=your_dashscope_sk_key

# Tip: Run `sops decrypt secrets/dev.vars.json > .dev.vars` to get all secrets
