# GitHub OAuth (for login)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Auth
BETTER_AUTH_SECRET=your_better_auth_secret_at_least_32_chars

# Tinybird (analytics) — use staging workspace tokens for local dev.
# The pre-populated values in secrets/dev.vars.json point at the
# `pollinations_enter_staging` workspace; do not paste prod tokens here.
TINYBIRD_INGEST_TOKEN=your_staging_workspace_ingest_token
TINYBIRD_READ_TOKEN=your_staging_workspace_read_token
TINYBIRD_SYNC_TOKEN=your_tinybird_sync_token

# Testing
PLN_ENTER_TOKEN=optional_pln_enter_token

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# OVHcloud (Whisper speech-to-text, Qwen, Mistral)
OVHCLOUD_API_KEY=your_ovhcloud_api_key_here

# Alibaba DashScope (Qwen3-TTS)
DASHSCOPE_API_KEY=your_dashscope_sk_key

# Tip: Run `sops decrypt secrets/dev.vars.json > .dev.vars` to get all secrets
