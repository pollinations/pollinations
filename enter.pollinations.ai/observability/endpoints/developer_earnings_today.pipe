DESCRIPTION >
    Recent developer earnings (BYOP markup) split by which balance the
    spending user paid from. `paid_week` aggregates earnings from events
    where the user was charged from their pack (paid) balance;
    `tier_week` aggregates earnings from tier-side debits.
    Window is the last 7 days (rolling). Earnings for hard-deleted app
    keys are excluded via inner join against the latest `d1_apikey` snapshot,
    matching the policy of `developer_earnings.pipe`.

TOKEN tinybird_read READ

NODE app_keys
SQL >
    %
    SELECT id AS app_key_id
    FROM d1_apikey
    WHERE synced_at = (SELECT max(synced_at) FROM d1_apikey)

NODE today
SQL >
    %
    SELECT
        sumIf(ge.total_price - ge.dev_price, ge.selected_meter_slug = 'v1:meter:pack') AS paid_week,
        sumIf(ge.total_price - ge.dev_price, ge.selected_meter_slug = 'v1:meter:tier') AS tier_week
    FROM generation_event ge
    INNER JOIN app_keys ak ON ge.api_key_client_id = ak.app_key_id
    WHERE ge.api_key_created_for_user_id = {{String(dev_user_id, '')}}
      AND ge.markup_rate > 0
      AND ge.total_price > ge.dev_price
      AND ge.start_time >= now() - INTERVAL 7 DAY

TYPE endpoint
