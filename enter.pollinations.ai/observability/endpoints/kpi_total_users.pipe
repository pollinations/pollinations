DESCRIPTION >
    Total user count from d1_user snapshot.

TOKEN model_usage READ

NODE total_users
SQL >
    %
    SELECT count() AS total
    FROM d1_user
    WHERE synced_at = (SELECT max(synced_at) FROM d1_user)
        AND created_at IS NOT NULL
        AND created_at >= {{Int64(min_created_at, 0)}}

TYPE endpoint
