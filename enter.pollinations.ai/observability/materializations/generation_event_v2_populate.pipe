DESCRIPTION >
    Backfills up to 12 months of authenticated, non-cached generation events
    into generation_event_v2 and keeps it current until direct ingestion is
    switched to the new datasource.

NODE generation_event_v2_populate_node
SQL >
    SELECT *
    FROM generation_event
    WHERE start_time >= now() - INTERVAL 12 MONTH
      AND user_id != ''
      AND user_id != 'undefined'
      AND cache_hit = false

TYPE MATERIALIZED
DATASOURCE generation_event_v2
