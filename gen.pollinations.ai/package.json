{
    "name": "pollinations-gen",
    "version": "1.0.0",
    "type": "module",
    "description": "Simplified API gateway for pollinations.ai",
    "scripts": {
        "decrypt-vars": "sops exec-file --no-fifo ../enter.pollinations.ai/secrets/dev.vars.json 'node scripts/push-generation-secrets.mjs {} local'",
        "dev": "npm run decrypt-vars && wrangler dev --port 8788 --local --persist-to .wrangler/state --show-interactive-dev-session false",
        "deploy:staging": "wrangler deploy --env staging",
        "deploy:production": "wrangler deploy --env production",
        "push-secrets:staging": "sops exec-file --no-fifo ../enter.pollinations.ai/secrets/staging.vars.json 'node scripts/push-generation-secrets.mjs {} staging'",
        "push-secrets:production": "sops exec-file --no-fifo ../enter.pollinations.ai/secrets/prod.vars.json 'node scripts/push-generation-secrets.mjs {} production'",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "docs:generate": "tsx scripts/generate-apidocs.ts"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20251202.0",
        "@scalar/openapi-to-markdown": "0.3.23",
        "@types/node": "24.10.1",
        "tsx": "4.20.6",
        "typescript": "^5.9.3",
        "vitest": "3.2.4",
        "wrangler": "^4.52.1"
    },
    "dependencies": {
        "@hono/standard-validator": "^0.2.2",
        "@logtape/logtape": "1.3.5",
        "@scalar/hono-api-reference": "0.9.32",
        "better-auth": "^1.4.17",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.44.7",
        "eventsource-parser": "3.0.6",
        "fast-json-stable-stringify": "^2.1.0",
        "hono": "4.10.6",
        "hono-openapi": "1.2.0",
        "nanoid": "5.1.6",
        "tailwind-merge": "3.4.0",
        "zod": "4.3.5"
    }
}
