{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["esnext", "dom", "dom.iterable"],
        "types": ["@cloudflare/workers-types", "node"],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@/auth.ts": ["../enter.pollinations.ai/src/auth.ts"],
            "@/db/schema/better-auth.ts": [
                "../enter.pollinations.ai/src/db/schema/better-auth.ts"
            ],
            "@/middleware/auth.ts": [
                "../enter.pollinations.ai/src/middleware/auth.ts"
            ],
            "@/middleware/balance.ts": [
                "../enter.pollinations.ai/src/middleware/balance.ts"
            ],
            "@/routes/account.ts": [
                "../enter.pollinations.ai/src/routes/account.ts"
            ],
            "@/utils/track-helpers.ts": [
                "../enter.pollinations.ai/src/utils/track-helpers.ts"
            ],
            "@/*": ["src/*"],
            "@shared/*": ["../shared/*"]
        }
    },
    "include": [
        "src/**/*",
        "worker-bindings.d.ts"
    ],
    "exclude": ["node_modules"]
}
