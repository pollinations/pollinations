# Discord Bot Token - Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# GitHub Personal Access Token - Get from https://github.com/settings/tokens
# Required scopes: repo (for creating issues)
GITHUB_TOKEN=your_github_token_here

# GitHub Repository for creating issues (format: owner/repo)
GITHUB_REPO=pollinations/pollinations

# Pollinations API Key - Required for AI enhancement
# Get from https://enter.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here