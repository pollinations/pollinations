{
    "name": "pollinations.ai",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "predev": "npm run build:ui",
        "build:ui": "npm run build --prefix ../packages/sdk && npm run build --prefix ../packages/ui",
        "build": "tsc --noEmit && vite build",
        "prebuild": "npm run build:ui",
        "build:staging": "CLOUDFLARE_ENV=staging vite build --mode=staging",
        "prebuild:staging": "npm run build:ui",
        "build:production": "CLOUDFLARE_ENV=production vite build --mode=production",
        "prebuild:production": "npm run build:ui",
        "preview": "vite preview",
        "deploy:staging": "npm run build:staging && wrangler deploy --config dist/pollinations_ai/wrangler.json",
        "deploy:production": "npm run build:production && wrangler deploy --config dist/pollinations_ai/wrangler.json"
    },
    "dependencies": {
        "@pollinations/ui": "file:../packages/ui",
        "@tanstack/react-router": "1.170.11",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.15.0",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/router-plugin": "1.168.14",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.6",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.4",
        "tailwindcss": "^4.3.0",
        "typescript": "^5.9.3",
        "vite": "^7.1.7",
        "vite-plugin-svgr": "^4.5.0",
        "vite-tsconfig-paths": "^5.1.4",
        "wrangler": "^4.49.0"
    }
}
