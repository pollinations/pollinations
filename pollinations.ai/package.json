{
    "name": "pollinations.ai",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "build:staging": "CLOUDFLARE_ENV=staging vite build --mode=staging",
        "build:production": "CLOUDFLARE_ENV=production vite build --mode=production",
        "test": "vitest run",
        "test:watch": "vitest",
        "preview": "vite preview",
        "deploy:staging": "npm run build:staging && wrangler deploy --config dist/pollinations_ai/wrangler.json",
        "deploy:production": "npm run build:production && wrangler deploy --config dist/pollinations_ai/wrangler.json"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.553.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^6.20.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.4.0"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.15.0",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.6",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.4",
        "autoprefixer": "^10.4.22",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.18",
        "typescript": "^5.9.3",
        "vite": "^7.1.7",
        "vite-plugin-svgr": "^4.5.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "3.2.6",
        "wrangler": "^4.49.0"
    }
}
