# ======================================================================
# TEXT.POLLINATIONS.AI CONFIGURATION
# ======================================================================

# ======================================================================
# AWS BEDROCK (Claude, Nova, GLM, MiniMax)
# ======================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ======================================================================
# AZURE (OpenAI, DeepSeek, Grok, Kimi, Mistral)
# ======================================================================
AZURE_MYCELI_PROD_API_KEY=your_azure_myceli_prod_api_key
AZURE_MYCELI_PROD_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_MYCELI_PROD_SWEDEN_API_KEY=your_azure_myceli_prod_sweden_api_key
AZURE_MYCELI_PROD_SWEDEN_ENDPOINT=https://your-endpoint.openai.azure.com/

# ======================================================================
# GOOGLE VERTEX AI (Gemini)
# ======================================================================
GOOGLE_PROJECT_ID=your_google_project_id
GOOGLE_CLIENT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY_ID=your_private_key_id
GOOGLE_PRIVATE_KEY=your_private_key

# ======================================================================
# OTHER PROVIDERS
# ======================================================================
DASHSCOPE_API_KEY=your_dashscope_api_key
OVHCLOUD_API_KEY=your_ovhcloud_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
STEPFUN_API_KEY=your_stepfun_api_key

# ======================================================================
# SERVICE CONFIGURATION
# ======================================================================
PORTKEY_GATEWAY_URL=your_portkey_gateway_url
PLN_ENTER_TOKEN=your_enter_token_here
PORT=16385
