{
    "name": "text.pollinations.ai",
    "version": "1.0.0",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "decrypt-vars": "sops decrypt secrets/env.json --output-type dotenv > .env",
        "start": "npx tsx startServer.ts",
        "start:dev": "npm run decrypt-vars && npx tsx startServer.ts",
        "dev": "npm run decrypt-vars && DEBUG=pollinations:* npx tsx --watch startServer.ts",
        "type-check": "tsc --noEmit",
        "validate-configs": "tsx configs/validateConfigKeys.ts",
        "test": "echo \"Error: no test specified\" && exit 1",
        "deploy:portkey": "bash scripts/deploy-portkey.sh"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "@hono/node-server": "^1.19.9",
        "axios": "^1.7.7",
        "debug": "^4.4.1",
        "dotenv": "^16.0.3",
        "eventsource-parser": "^3.0.2",
        "hono": "^4.11.4",
        "jsonwebtoken": "^9.0.2",
        "node-fetch": "^3.3.2",
        "tsx": "^4.20.3",
        "typescript": "^5.8.3",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@types/node": "^25.2.3"
    }
}
